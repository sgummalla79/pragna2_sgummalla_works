# ── Auth0 ────────────────────────────────────────────────────────────────────
# Auth0 tenant domain (no https://)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Auth0 SPA application Client ID
VITE_AUTH0_CLIENT_ID=your-client-id

# Auth0 API audience (the identifier of the API you registered in Auth0)
VITE_AUTH0_AUDIENCE=https://api.pragna.example.com

# ── FastAPI backend ───────────────────────────────────────────────────────────
# Base URL (no trailing slash)
# Dev: http://localhost:8000 | Prod: https://api.pragna.example.com
VITE_API_BASE_URL=http://localhost:8000

# AG-UI native chat base path. Routes: GET /pragna/agents (discovery) and
# POST /pragna/agents/{name} (run, SSE stream).
VITE_PRAGNA_BASE_URL=http://localhost:8000/pragna

# Minimum log level: debug | info | warn | error
# In production builds, warn is the effective floor regardless of this value
VITE_LOG_LEVEL=debug

# Feature flags
VITE_FEATURE_FLOW_BUILDER=true

# App metadata
VITE_APP_NAME=Pragna
VITE_APP_VERSION=0.1.0
