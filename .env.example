# FastAPI backend base URL (no trailing slash)
# Dev: http://localhost:8000 | Prod: https://api.pragna.example.com
VITE_API_BASE_URL=http://localhost:8000

# CopilotKit SSE runtime endpoint (NOT a REST endpoint — CopilotKit SDK only)
VITE_COPILOTKIT_URL=http://localhost:8000/pragna

# Token refresh path used by the auth interceptor
VITE_REFRESH_TOKEN_PATH=/api/auth/refresh

# Minimum log level: debug | info | warn | error
# In production builds, warn is the effective floor regardless of this value
VITE_LOG_LEVEL=debug

# Feature flags
VITE_FEATURE_FLOW_BUILDER=true

# App metadata
VITE_APP_NAME=Pragna
VITE_APP_VERSION=0.1.0
