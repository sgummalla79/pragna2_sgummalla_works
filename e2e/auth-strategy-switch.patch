@@ -0,0 +1,40 @@
+import { describe, expect, it } from 'vitest';
+import type { AxiosInstance } from 'axios';
+
+import { pickAuthRepo } from '@/presentation/providers/pickAuthRepo';
+import { AuthRepository } from '@/infrastructure/repositories/AuthRepository';
+import { Auth0Repository } from '@/infrastructure/auth0/Auth0Repository';
+
+const axios = {} as AxiosInstance;
+
+describe('pickAuthRepo', () => {
+  it("returns AuthRepository when VITE_AUTH_STRATEGY='local'", () => {
+    const repo = pickAuthRepo({ VITE_AUTH_STRATEGY: 'local', PROD: false }, axios);
+    expect(repo).toBeInstanceOf(AuthRepository);
+  });
+
+  it("returns Auth0Repository when VITE_AUTH_STRATEGY='auth0'", () => {
+    const repo = pickAuthRepo({ VITE_AUTH_STRATEGY: 'auth0', PROD: false }, axios);
+    expect(repo).toBeInstanceOf(Auth0Repository);
+  });
+
+  it('defaults to Auth0 in dev when the strategy is unset (existing behaviour preserved)', () => {
+    const repo = pickAuthRepo({ PROD: false }, axios);
+    expect(repo).toBeInstanceOf(Auth0Repository);
+  });
+
+  it('THROWS in production when the strategy is unset — no silent fallback', () => {
+    expect(() => pickAuthRepo({ PROD: true }, axios)).toThrow(/VITE_AUTH_STRATEGY/i);
+  });
+
+  it('THROWS on an unknown strategy', () => {
+    expect(() => pickAuthRepo({ VITE_AUTH_STRATEGY: 'oauth', PROD: false }, axios)).toThrow(
+      /Unknown VITE_AUTH_STRATEGY/i,
+    );
+  });
+
+  it('is case-insensitive + whitespace-tolerant', () => {
+    expect(pickAuthRepo({ VITE_AUTH_STRATEGY: '  LOCAL  ', PROD: false }, axios)).toBeInstanceOf(AuthRepository);
+    expect(pickAuthRepo({ VITE_AUTH_STRATEGY: 'Auth0', PROD: false }, axios)).toBeInstanceOf(Auth0Repository);
+  });
+});
