diff --git a/src/presentation/providers/pickAuthRepo.ts b/src/presentation/providers/pickAuthRepo.ts
new file mode 100644
index 0000000..ca8c6e2
--- /dev/null
+++ b/src/presentation/providers/pickAuthRepo.ts
@@ -0,0 +1,39 @@
+/**
+ * Choose the `IAuthRepository` implementation from the active auth
+ * strategy. Extracted from `ServiceProvider` so the decision is unit-
+ * testable without rendering the provider tree.
+ *
+ * **Production must set `VITE_AUTH_STRATEGY` explicitly.** Silent
+ * fallback would risk degrading to local auth (which posts the user's
+ * password to our backend) when an Auth0 deployment was intended. In
+ * dev we default to `auth0` so existing developer setups don't change
+ * behavior — opt into local with `VITE_AUTH_STRATEGY=local` (e.g. in
+ * `.env.local` or a one-off shell env when running `npm run dev`).
+ */
+
+import type { AxiosInstance } from 'axios';
+
+import type { IAuthRepository } from '@/application/ports/IAuthRepository';
+import { Auth0Repository } from '@/infrastructure/auth0/Auth0Repository';
+import { AuthRepository } from '@/infrastructure/repositories/AuthRepository';
+
+/** Subset of `ImportMetaEnv` this helper reads. */
+export interface PickAuthEnv {
+  VITE_AUTH_STRATEGY?: string;
+  PROD: boolean;
+}
+
+export function pickAuthRepo(env: PickAuthEnv, axios: AxiosInstance): IAuthRepository {
+  const raw = (env.VITE_AUTH_STRATEGY ?? '').trim().toLowerCase();
+  if (env.PROD && !raw) {
+    throw new Error(
+      'VITE_AUTH_STRATEGY must be set in production (local|auth0). ' +
+      'Silent fallback would risk degrading to local auth — passwords ' +
+      'flowing through the backend — when Auth0 was intended.',
+    );
+  }
+  const strategy = raw || 'auth0';
+  if (strategy === 'local') return new AuthRepository(axios);
+  if (strategy === 'auth0') return new Auth0Repository(axios);
+  throw new Error(`Unknown VITE_AUTH_STRATEGY='${raw}'. Expected 'local' or 'auth0'.`);
+}
